{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vertex",
  "aliases": ["vertex", "vtx"],
  "scopeName": "source.vertex",
  "fileTypes": ["vtx"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#annotation" },
    { "include": "#import-declaration" },
    { "include": "#keyword-modifier" },
    { "include": "#keyword-declaration" },
    { "include": "#fn-declaration" },
    { "include": "#type-declaration" },
    { "include": "#const-declaration" },
    { "include": "#extern-declaration" },
    { "include": "#keyword-control" },
    { "include": "#keyword-let" },
    { "include": "#keyword-debug" },
    { "include": "#builtin-constant" },
    { "include": "#boolean" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#placeholder" },
    { "include": "#operator" },
    { "include": "#builtin-type" },
    { "include": "#constructor-call" },
    { "include": "#function-call" },
    { "include": "#method-call" },
    { "include": "#type-reference" },
    { "include": "#punctuation" },
    { "include": "#variable" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.vertex",
      "match": "//.*$"
    },

    "string": {
      "name": "string.quoted.double.vertex",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.vertex" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.vertex" }
      },
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-interpolation" },
        { "include": "#string-dollar" }
      ]
    },

    "string-escape": {
      "name": "constant.character.escape.vertex",
      "match": "\\\\[\"\\\\nrt$]"
    },

    "string-interpolation": {
      "name": "meta.interpolation.vertex",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.vertex" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.vertex" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#builtin-constant" },
        { "include": "#keyword-control" },
        { "include": "#keyword-let" },
        { "include": "#operator" },
        { "include": "#builtin-type" },
        { "include": "#constructor-call" },
        { "include": "#function-call" },
        { "include": "#method-call" },
        { "include": "#type-reference" },
        { "include": "#punctuation" },
        { "include": "#variable" }
      ]
    },

    "string-dollar": {
      "name": "constant.character.escape.dollar.vertex",
      "match": "\\$(?!\\{)"
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.vertex",
          "match": "\\b[0-9]+\\.[0-9]+d\\b"
        },
        {
          "name": "constant.numeric.long.vertex",
          "match": "\\b[0-9]+L\\b"
        },
        {
          "name": "constant.numeric.double.vertex",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.vertex",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "boolean": {
      "name": "constant.language.boolean.vertex",
      "match": "\\b(true|false)\\b"
    },

    "builtin-constant": {
      "patterns": [
        {
          "name": "constant.language.self.vertex",
          "match": "\\bself\\b"
        },
        {
          "name": "support.type.void.vertex",
          "match": "\\bVoid\\b"
        },
        {
          "name": "support.function.constructor.vertex",
          "match": "\\b(Some|None|Ok|Error)\\b"
        }
      ]
    },

    "placeholder": {
      "name": "variable.language.placeholder.vertex",
      "match": "\\b_\\b"
    },

    "annotation": {
      "patterns": [
        {
          "name": "meta.annotation.call.vertex",
          "begin": "(@)([A-Z][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.annotation.vertex" },
            "2": { "name": "entity.other.attribute-name.vertex" },
            "3": { "name": "punctuation.section.annotation.begin.vertex" }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": { "name": "punctuation.section.annotation.end.vertex" }
          },
          "patterns": [
            { "include": "#string" },
            { "include": "#number" },
            { "include": "#boolean" },
            { "include": "#builtin-type" },
            { "include": "#annotation-argument" },
            { "include": "#punctuation" }
          ]
        },
        {
          "name": "meta.annotation.vertex",
          "match": "(@)([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.vertex" },
            "2": { "name": "entity.other.attribute-name.vertex" }
          }
        }
      ]
    },

    "annotation-argument": {
      "match": "([a-z_][a-zA-Z0-9_]*)\\s*(:)",
      "captures": {
        "1": { "name": "variable.parameter.vertex" },
        "2": { "name": "punctuation.separator.key-value.vertex" }
      }
    },

    "import-declaration": {
      "match": "\\b(import)\\s+([a-z_][a-zA-Z0-9_.]*)(\\s+(as)\\s+([a-z_][a-zA-Z0-9_]*))?",
      "captures": {
        "1": { "name": "keyword.control.import.vertex" },
        "2": { "name": "entity.name.namespace.vertex" },
        "4": { "name": "keyword.control.import.vertex" },
        "5": { "name": "entity.name.namespace.alias.vertex" }
      }
    },

    "keyword-modifier": {
      "name": "storage.modifier.vertex",
      "match": "\\b(pub|global|mutable|opaque)\\b"
    },

    "keyword-declaration": {
      "name": "keyword.other.vertex",
      "match": "\\b(fn|type|const|extern|new|method|field|var|enum|assert)\\b"
    },

    "keyword-control": {
      "name": "keyword.control.vertex",
      "match": "\\b(if|else|match|for|in|return)\\b"
    },

    "keyword-let": {
      "name": "keyword.other.let.vertex",
      "match": "\\blet\\b"
    },

    "keyword-debug": {
      "name": "keyword.other.debug.vertex",
      "match": "\\bdebug\\b"
    },

    "fn-declaration": {
      "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.other.vertex" },
        "2": { "name": "entity.name.function.vertex" }
      }
    },

    "type-declaration": {
      "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.other.vertex" },
        "2": { "name": "entity.name.type.vertex" }
      }
    },

    "const-declaration": {
      "match": "\\b(const)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.other.vertex" },
        "2": { "name": "variable.other.constant.vertex" }
      }
    },

    "extern-declaration": {
      "patterns": [
        {
          "match": "\\b(extern)\\s+(type|enum)\\s+([A-Z][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.other.vertex" },
            "2": { "name": "keyword.other.vertex" },
            "3": { "name": "entity.name.type.vertex" }
          }
        },
        {
          "match": "\\b(extern)\\s+(fn|method)\\s+([A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*)\\.([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.vertex" },
            "2": { "name": "keyword.other.vertex" },
            "3": { "name": "entity.name.type.vertex" },
            "4": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "match": "\\b(extern)\\s+(fn)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.vertex" },
            "2": { "name": "keyword.other.vertex" },
            "3": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "match": "\\b(extern)\\s+(new)\\s+([A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*)(?:\\.([a-z_][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.other.vertex" },
            "2": { "name": "keyword.other.vertex" },
            "3": { "name": "entity.name.type.vertex" },
            "4": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "match": "\\b(extern)\\s+(field|var)\\s+([A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*)\\.([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.vertex" },
            "2": { "name": "keyword.other.vertex" },
            "3": { "name": "entity.name.type.vertex" },
            "4": { "name": "variable.other.property.vertex" }
          }
        }
      ]
    },

    "operator": {
      "patterns": [
        { "name": "keyword.operator.pipe.vertex", "match": "\\|>" },
        { "name": "keyword.operator.arrow.vertex", "match": "=>" },
        { "name": "keyword.operator.comparison.vertex", "match": "(==|!=|<=|>=)" },
        { "name": "keyword.operator.logical.vertex", "match": "(&&|\\|\\|)" },
        { "name": "keyword.operator.spread.vertex", "match": "\\.{2,3}" },
        { "name": "keyword.operator.propagation.vertex", "match": "\\?" },
        { "name": "keyword.operator.arithmetic.vertex", "match": "[+\\-*/%]" },
        { "name": "keyword.operator.comparison.vertex", "match": "[<>]" },
        { "name": "keyword.operator.logical.vertex", "match": "!" },
        { "name": "keyword.operator.closure.vertex", "match": "\\|" },
        { "name": "keyword.operator.assignment.vertex", "match": "(?<!=)=(?!=|>)" }
      ]
    },

    "builtin-type": {
      "name": "support.type.builtin.vertex",
      "match": "\\b(Int|Long|Double|Decimal|Bool|String|Void|Id|Date|Datetime|DateFormat|Option|Result|List|Map|Set|AuraError|DmlError|ApexException|Database)\\b"
    },

    "type-reference": {
      "patterns": [
        {
          "comment": "Apex-qualified type Foo.Bar or deep Foo.Bar.Baz",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.[A-Z][a-zA-Z0-9_]*)+\\b",
          "captures": {
            "0": { "name": "entity.name.type.vertex" }
          }
        },
        {
          "comment": "Module-qualified type foo.Bar — lowercase prefix, PascalCase suffix",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\.([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.vertex" },
            "2": { "name": "entity.name.type.vertex" }
          }
        },
        {
          "name": "entity.name.type.vertex",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },

    "constructor-call": {
      "comment": "TypeName( — variant construction / constructor call",
      "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.constructor.vertex" }
      }
    },

    "method-call": {
      "comment": "expr.method( — method-call invocation; the method name is styled as a call",
      "match": "(\\.)([a-z_][a-zA-Z0-9_]*)\\s*(?=\\(|<)",
      "captures": {
        "1": { "name": "punctuation.accessor.vertex" },
        "2": { "name": "entity.name.function.method.vertex" }
      }
    },

    "function-call": {
      "comment": "foo( — plain function call",
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.vertex" }
      }
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.brackets.vertex", "match": "[()\\[\\]{}]" },
        { "name": "punctuation.special.tuple-or-set.vertex", "match": "#[({]" },
        { "name": "punctuation.separator.comma.vertex", "match": "," },
        { "name": "punctuation.separator.colon.vertex", "match": ":" },
        { "name": "punctuation.accessor.vertex", "match": "\\." }
      ]
    },

    "variable": {
      "name": "variable.other.vertex",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }
  }
}
